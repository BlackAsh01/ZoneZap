# ZoneZap Vercel API – copy to .env.local and fill in
# Get Supabase: https://supabase.com – create project, run supabase/schema.sql in SQL Editor
# Get Service Role Key: Project Settings -> API -> service_role (secret)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# JWT secret for auth tokens (use a long random string in production)
JWT_SECRET=your-jwt-secret-min-32-chars

# Firebase FCM: Project Settings -> Service accounts -> Generate new private key -> paste JSON as one line or path
# Optional: for cron (overdue reminders) and FCM push
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
CRON_SECRET=optional-secret-for-cron-route
